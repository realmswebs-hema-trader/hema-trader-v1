rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFounderAdminEmail() {
      return signedIn() &&
        request.auth.token.email == 'realmswebs@gmail.com';
    }

    function isTemporaryModeratorEmail() {
      return signedIn() &&
        request.auth.token.email == 'realmscity@gmail.com';
    }

    function isAdmin() {
      return signedIn() &&
        (
          isFounderAdminEmail() ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true ||
              (
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles is list &&
                'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles
              )
            )
          )
        );
    }
    function isUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsListing(data) {
      return signedIn() &&
        (
          data.ownerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.userId == request.auth.uid ||
          data.createdBy == request.auth.uid
        );
    }

    function listingExists(listingId) {
      return listingId is string &&
        exists(/databases/$(database)/documents/listings/$(listingId));
    }

    function ownsListingById(listingId) {
      return signedIn() &&
        listingExists(listingId) &&
        ownsListing(get(/databases/$(database)/documents/listings/$(listingId)).data);
    }

    function tradeExists(tradeId) {
      return exists(/databases/$(database)/documents/trades/$(tradeId));
    }

    function tradeData(tradeId) {
      return get(/databases/$(database)/documents/trades/$(tradeId)).data;
    }

    function deliveryRequestExists(requestId) {
      return exists(/databases/$(database)/documents/deliveryRequests/$(requestId));
    }

    function deliveryRequestData(requestId) {
      return get(/databases/$(database)/documents/deliveryRequests/$(requestId)).data;
    }

    function isTradeParticipant(data) {
      return signedIn() &&
        (
          isAdmin() ||
          data.buyerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.driverId == request.auth.uid ||
          data.assignedDriverId == request.auth.uid ||
          data.moderatorId == request.auth.uid ||
          data.userId == request.auth.uid ||
          data.createdBy == request.auth.uid ||
          data.requesterId == request.auth.uid ||
          data.requestedBy == request.auth.uid ||
          (
            data.participantIds is list &&
            request.auth.uid in data.participantIds
          ) ||
          (
            data.participants is list &&
            request.auth.uid in data.participants
          ) ||
          (
            data.memberIds is list &&
            request.auth.uid in data.memberIds
          ) ||
          (
            data.userIds is list &&
            request.auth.uid in data.userIds
          )
        );
    }

    function isTradeParticipantById(tradeId) {
      return signedIn() &&
        tradeExists(tradeId) &&
        isTradeParticipant(tradeData(tradeId));
    }

    function isDeliveryParticipant(data) {
      return signedIn() &&
        (
          isAdmin() ||
          data.buyerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.driverId == request.auth.uid ||
          data.assignedDriverId == request.auth.uid ||
          data.moderatorId == request.auth.uid ||
          data.userId == request.auth.uid ||
          data.createdBy == request.auth.uid ||
          data.requesterId == request.auth.uid ||
          data.requestedBy == request.auth.uid ||
          data.customerId == request.auth.uid ||
          data.ownerId == request.auth.uid ||
          (
            data.participantIds is list &&
            request.auth.uid in data.participantIds
          ) ||
          (
            data.participants is list &&
            request.auth.uid in data.participants
          ) ||
          (
            data.driverIds is list &&
            request.auth.uid in data.driverIds
          ) ||
          (
            data.tradeId is string &&
            isTradeParticipantById(data.tradeId)
          )
        );
    }

    function isDeliveryParticipantById(requestId) {
      return signedIn() &&
        deliveryRequestExists(requestId) &&
        isDeliveryParticipant(deliveryRequestData(requestId));
    }

    function isMessageParticipant(data) {
      return signedIn() &&
        (
          isAdmin() ||
          data.senderId == request.auth.uid ||
          data.recipientId == request.auth.uid ||
          data.buyerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.driverId == request.auth.uid ||
          data.assignedDriverId == request.auth.uid ||
          data.moderatorId == request.auth.uid ||
          data.userId == request.auth.uid ||
          data.createdBy == request.auth.uid ||
          (
            data.participantIds is list &&
            request.auth.uid in data.participantIds
          ) ||
          (
            data.participants is list &&
            request.auth.uid in data.participants
          ) ||
          (
            data.memberIds is list &&
            request.auth.uid in data.memberIds
          ) ||
          (
            data.userIds is list &&
            request.auth.uid in data.userIds
          ) ||
          (
            data.tradeId is string &&
            isTradeParticipantById(data.tradeId)
          ) ||
          (
            data.deliveryRequestId is string &&
            isDeliveryParticipantById(data.deliveryRequestId)
          )
        );
    }

    function isNotificationOwner(data) {
      return signedIn() &&
        (
          isAdmin() ||
          data.userId == request.auth.uid ||
          data.recipientId == request.auth.uid
        );
    }

    function safeSelfRoleData(data) {
      return
        (
          !('roles' in data) ||
          (
            data.roles is list &&
            data.roles.hasOnly(['buyer', 'seller', 'driver']) &&
            data.roles.size() <= 3
          )
        ) &&
        (
          !('activeRole' in data) ||
          data.activeRole == null ||
          data.activeRole in ['buyer', 'seller', 'driver', '']
        );
    }

    function safeSelfSubscriptionData(data) {
      return !('subscription' in data) ||
        (
          data.subscription is map &&
          (
            !('plan' in data.subscription) ||
            data.subscription.plan == 'free'
          ) &&
          (
            !('paymentStatus' in data.subscription) ||
            data.subscription.paymentStatus in ['trial', 'unpaid']
          ) &&
          (
            !('status' in data.subscription) ||
            data.subscription.status in ['active', 'expired', 'cancelled']
          )
        );
    }

    function criticalUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'admin',
          'isAdmin',
          'permissions',
          'verificationStatus',
          'sellerVerified',
          'driverVerified',
          'businessVerified',
          'identityVerified',
          'phoneVerified',
          'trustScore',
          'trustLevel',
          'walletBalance',
          'availableBalance',
          'escrowBalance',
          'pendingWithdrawalBalance',
          'totalEarned',
          'isModerator',
          'moderatorVerified',
          'moderatorStatus',
          'moderatorApplicationStatus',
          'moderatorApprovedAt',
          'moderatorApprovedBy',
          'moderatorRegions',
          'moderatorRoutes',
          'moderatorAvailability',
          'moderatorWalletBalance',
          'moderatorCanWithdrawImmediately',
          'moderatorRating',
          'completedModeratorDeliveries'
        ]);
    }

    function isApprovedModerator(userId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.isModerator == true &&
        get(/databases/$(database)/documents/users/$(userId)).data.moderatorVerified == true &&
        get(/databases/$(database)/documents/users/$(userId)).data.moderatorStatus == 'approved';
    }

    function isModeratorDeliveryParticipant(data) {
      return signedIn() &&
        (
          isAdmin() ||
          data.buyerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.moderatorId == request.auth.uid ||
          (
            data.participantIds is list &&
            request.auth.uid in data.participantIds
          ) ||
          (
            data.tradeId is string &&
            isTradeParticipantById(data.tradeId)
          )
        );
    }

    function validModeratorDeliveryCreate(data) {
      return signedIn() &&
        data.buyerId == request.auth.uid &&
        data.tradeId is string &&
        isTradeParticipantById(data.tradeId) &&
        data.moderatorId is string &&
        isApprovedModerator(data.moderatorId) &&
        data.status == 'moderator_requested' &&
        data.moderatorPaymentStatus == 'unpaid' &&
        data.moderatorFee is number &&
        data.moderatorFee > 0 &&
        data.moderatorPlatformFee is number &&
        data.moderatorPlatformFee >= 0 &&
        data.moderatorNetEarning is number &&
        data.moderatorNetEarning >= 0 &&
        data.moderatorNetEarning + data.moderatorPlatformFee == data.moderatorFee;
    }

    function assignedModeratorCanUpdateDelivery() {
      return isApprovedModerator(request.auth.uid) &&
        resource.data.moderatorId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'moderatorAcceptedAt',
          'moderatorPickedUpAt',
          'moderatorInTransitAt',
          'moderatorDeliveredAt',
          'updatedAt'
        ]) &&
        request.resource.data.status in [
          'moderator_accepted',
          'moderator_declined',
          'picked_up_by_moderator',
          'in_transit_by_moderator',
          'delivered_by_moderator'
        ];
    }

    function buyerCanRequestModeratorPayment() {
      return signedIn() &&
        resource.data.buyerId == request.auth.uid &&
        resource.data.moderatorPaymentStatus == 'unpaid' &&
        request.resource.data.moderatorPaymentStatus == 'payment_requested' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderatorPaymentStatus',
          'updatedAt'
        ]);
    }

    function safeTemporaryModeratorSelfActivation() {
      return isTemporaryModeratorEmail() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'roles',
          'isModerator',
          'moderatorVerified',
          'moderatorStatus',
          'moderatorApplicationStatus',
          'moderatorAvailability',
          'moderatorRegions',
          'moderatorRoutes',
          'moderatorCanWithdrawImmediately',
          'email',
          'updatedAt',
          'moderatorApprovedAt',
          'moderatorApprovedBy'
        ]) &&
        request.resource.data.roles is list &&
        request.resource.data.roles.hasOnly(['buyer', 'seller', 'moderator']) &&
        request.resource.data.isModerator == true &&
        request.resource.data.moderatorVerified == true &&
        request.resource.data.moderatorStatus == 'approved' &&
        request.resource.data.moderatorApplicationStatus == 'approved' &&
        request.resource.data.moderatorAvailability in ['available', 'busy', 'offline'] &&
        request.resource.data.moderatorRegions is list &&
        request.resource.data.moderatorRoutes is list &&
        request.resource.data.moderatorCanWithdrawImmediately == true;
    }

    function safeModeratorAvailabilityUpdate(userId) {
      return isUser(userId) &&
        isApprovedModerator(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'moderatorAvailability',
          'updatedAt'
        ]) &&
        request.resource.data.moderatorAvailability in [
          'available',
          'busy',
          'offline'
        ];
    }

    function safeSelfUserWrite(data) {
      return safeSelfRoleData(data) &&
        safeSelfSubscriptionData(data) &&
        !criticalUserFieldsChanged();
    }

    function safeNewUserProfile(data) {
      return safeSelfRoleData(data) &&
        safeSelfSubscriptionData(data) &&
        (
          !('admin' in data) ||
          data.admin == false
        ) &&
        (
          !('isAdmin' in data) ||
          data.isAdmin == false
        ) &&
        (
          !('verificationStatus' in data) ||
          data.verificationStatus in ['unverified', 'pending']
        ) &&
        (
          !('isModerator' in data) ||
          data.isModerator == false
        ) &&
        (
          !('moderatorVerified' in data) ||
          data.moderatorVerified == false
        ) &&
        (
          !('moderatorStatus' in data) ||
          data.moderatorStatus in [null, '', 'pending_review']
        ) &&
        (
          !('moderatorApplicationStatus' in data) ||
          data.moderatorApplicationStatus in [null, '', 'pending_review']
        );
    }

    function listingRevenueFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'boost',
          'isBoosted',
          'boostTier',
          'boostExpiresAt',
          'sellerSubscriptionPlan',
          'listingLimitAtCreation',
          'platformRevenueId'
        ]);
    }

    function safeListingBoostDefaults(data) {
      return isAdmin() ||
        (
          (
            !('isBoosted' in data) ||
            data.isBoosted == null ||
            data.isBoosted == false
          ) &&
          (
            !('boost' in data) ||
            data.boost == null ||
            (
              data.boost is map &&
              (
                !('isBoosted' in data.boost) ||
                data.boost.isBoosted == false
              )
            )
          )
        );
    }

    function tradeRevenueFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'platformFee',
          'sellerPayout',
          'driverCommission',
          'deliveryCommission',
          'platformRevenueId',
          'deliveryRevenueId',
          'sellerPayoutTransactionId',
          'driverPayoutTransactionId'
        ]);
    }

    function isValidListing(data) {
      return signedIn()

        && data.keys().hasAny([
          'title',
          'name',
          'productName'
        ])

        && data.keys().hasAny([
          'price',
          'amount',
          'priceValue'
        ])

        && (ownsListing(data) || isAdmin())

        && (!('ownerId' in data) || data.ownerId == null || data.ownerId is string)
        && (!('sellerId' in data) || data.sellerId == null || data.sellerId is string)
        && (!('userId' in data) || data.userId == null || data.userId is string)
        && (!('createdBy' in data) || data.createdBy == null || data.createdBy is string)

        && (!('title' in data) || data.title == null || data.title is string)
        && (!('name' in data) || data.name == null || data.name is string)
        && (!('productName' in data) || data.productName == null || data.productName is string)
        && (!('description' in data) || data.description == null || data.description is string)

        && (!('price' in data) || data.price == null || data.price is number || data.price is string)
        && (!('amount' in data) || data.amount == null || data.amount is number || data.amount is string)
        && (!('priceValue' in data) || data.priceValue == null || data.priceValue is number || data.priceValue is string)
        && (!('priceDisplay' in data) || data.priceDisplay == null || data.priceDisplay is string)

        && (!('quantity' in data) || data.quantity == null || data.quantity is string || data.quantity is number)
        && (!('category' in data) || data.category == null || data.category is string)

        && (
          !('status' in data) ||
          data.status == null ||
          data.status in [
            'active',
            'available',
            'sold',
            'deleted',
            'cancelled',
            'reserved',
            'in_trade',
            'draft'
          ]
        )

        && (
          !('listingStatus' in data) ||
          data.listingStatus == null ||
          data.listingStatus in [
            'active',
            'available',
            'reserved',
            'in_trade',
            'sold',
            'cancelled',
            'draft'
          ]
        )

        && (
          !('inventoryType' in data) ||
          data.inventoryType == null ||
          data.inventoryType in [
            'single',
            'stock',
            'single_product',
            'multiple'
          ]
        )

        && (!('stockStatus' in data) || data.stockStatus == null || data.stockStatus is string)
        && (!('activeTradeId' in data) || data.activeTradeId == null || data.activeTradeId is string)

        && (!('currency' in data) || data.currency == null || data.currency is string)
        && (!('currencyCode' in data) || data.currencyCode == null || data.currencyCode is string)
        && (!('currencyLabel' in data) || data.currencyLabel == null || data.currencyLabel is string)
        && (!('currencyLocale' in data) || data.currencyLocale == null || data.currencyLocale is string)
        && (!('country' in data) || data.country == null || data.country is string)

        && (!('metadata' in data) || data.metadata == null || data.metadata is map)

        && (!('images' in data) || data.images == null || data.images is list)
        && (!('imageUrls' in data) || data.imageUrls == null || data.imageUrls is list)
        && (!('failedImageNames' in data) || data.failedImageNames == null || data.failedImageNames is list)

        && (
          !('imageUploadStatus' in data) ||
          data.imageUploadStatus == null ||
          data.imageUploadStatus in [
            'none',
            'uploaded',
            'partial',
            'failed'
          ]
        )

        && (!('location' in data) || data.location == null || data.location is string || data.location is map)
        && (!('locationName' in data) || data.locationName == null || data.locationName is string)
        && (!('latitude' in data) || data.latitude == null || data.latitude is number)
        && (!('longitude' in data) || data.longitude == null || data.longitude is number)
        && (!('currentLocation' in data) || data.currentLocation == null || data.currentLocation is map)
        && (!('gpsAccuracy' in data) || data.gpsAccuracy == null || data.gpsAccuracy is number)
        && (!('gpsSource' in data) || data.gpsSource == null || data.gpsSource is string)
        && (!('isGeoTagged' in data) || data.isGeoTagged == null || data.isGeoTagged is bool)

        && (!('soldAt' in data) || data.soldAt == null || data.soldAt is timestamp)
        && (!('reservedAt' in data) || data.reservedAt == null || data.reservedAt is timestamp)

        && (!('isBoosted' in data) || data.isBoosted == null || data.isBoosted is bool)
        && (!('boost' in data) || data.boost == null || data.boost is map)

        && (
          !('boostTier' in data) ||
          data.boostTier == null ||
          data.boostTier in ['standard', 'premium']
        )

        && (!('boostExpiresAt' in data) || data.boostExpiresAt == null || data.boostExpiresAt is timestamp)

        && (
          !('sellerSubscriptionPlan' in data) ||
          data.sellerSubscriptionPlan == null ||
          data.sellerSubscriptionPlan in ['free', 'starter', 'pro', 'business']
        )

        && (
          !('listingLimitAtCreation' in data) ||
          data.listingLimitAtCreation == null ||
          data.listingLimitAtCreation is number ||
          data.listingLimitAtCreation is string
        )

        && (
          !('createdAt' in data) ||
          data.createdAt == null ||
          data.createdAt == request.time ||
          data.createdAt is timestamp
        )

        && (
          !('updatedAt' in data) ||
          data.updatedAt == null ||
          data.updatedAt == request.time ||
          data.updatedAt is timestamp
        );
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update, delete: if isFounderAdminEmail();
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isAdmin() ||
        (
          isUser(userId) &&
          safeNewUserProfile(request.resource.data)
        );

      allow update: if isAdmin() ||
        (
          isUser(userId) &&
          (
            safeSelfUserWrite(request.resource.data) ||
            safeTemporaryModeratorSelfActivation() ||
            safeModeratorAvailabilityUpdate(userId)
          )
        );

      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if isUser(userId) || isAdmin();

        allow create: if signedIn();

        allow update: if isUser(userId) || isAdmin();

        allow delete: if isUser(userId) || isAdmin();
      }
    }

    match /listings/{listingId} {
      allow read: if true;

      allow create: if isValidListing(request.resource.data) &&
        safeListingBoostDefaults(request.resource.data);

      allow update: if signedIn()
        && (
          isAdmin() ||
          ownsListing(resource.data) ||
          ownsListing(request.resource.data)
        )
        && isValidListing(request.resource.data)
        && (
          isAdmin() ||
          !listingRevenueFieldsChanged()
        );

      allow delete: if signedIn()
        && (
          isAdmin() ||
          ownsListing(resource.data)
        );
    }

    match /trades/{tradeId} {
      allow read: if isTradeParticipant(resource.data);

      allow create: if signedIn()
        && (
          isAdmin() ||
          request.resource.data.buyerId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.createdBy == request.auth.uid
        )
        && (
          !('sellerId' in request.resource.data) ||
          !('buyerId' in request.resource.data) ||
          request.resource.data.sellerId != request.resource.data.buyerId
        )
        && (
          !('listingId' in request.resource.data) ||
          !ownsListingById(request.resource.data.listingId) ||
          isAdmin()
        );

      allow update: if isAdmin() ||
        (
          (
            isTradeParticipant(resource.data) ||
            isTradeParticipant(request.resource.data)
          ) &&
          !tradeRevenueFieldsChanged()
        );

      allow delete: if isAdmin();

      match /offers/{offerId} {
        allow read: if isTradeParticipantById(tradeId);
        allow create: if isTradeParticipantById(tradeId);
        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isTradeParticipantById(tradeId);

        allow create: if isTradeParticipantById(tradeId)
          && (
            isAdmin() ||
            request.resource.data.senderId == request.auth.uid ||
            request.resource.data.userId == request.auth.uid ||
            request.resource.data.createdBy == request.auth.uid
          );

        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }

      match /deliveryOffers/{offerId} {
        allow read: if isTradeParticipantById(tradeId);
        allow create: if isTradeParticipantById(tradeId);
        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }

      match /driverOffers/{offerId} {
        allow read: if isTradeParticipantById(tradeId);
        allow create: if isTradeParticipantById(tradeId);
        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }

      match /deliveryMessages/{messageId} {
        allow read: if isTradeParticipantById(tradeId);
        allow create: if isTradeParticipantById(tradeId);
        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }

      match /{subCollection}/{docId} {
        allow read: if isTradeParticipantById(tradeId);
        allow create: if isTradeParticipantById(tradeId);
        allow update: if isTradeParticipantById(tradeId);
        allow delete: if isAdmin();
      }
    }

    match /messages/{messageId} {
      allow read: if isMessageParticipant(resource.data);

      allow create: if signedIn()
        && (
          isAdmin() ||
          isMessageParticipant(request.resource.data) ||
          request.resource.data.senderId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.createdBy == request.auth.uid
        );

      allow update: if isMessageParticipant(resource.data) ||
        isMessageParticipant(request.resource.data);

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isNotificationOwner(resource.data);

      allow create: if signedIn();

      allow update: if isNotificationOwner(resource.data) ||
        isNotificationOwner(request.resource.data);

      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          signedIn() &&
          request.resource.data.followerId == request.auth.uid &&
          request.resource.data.followingId is string &&
          request.resource.data.followingId != request.auth.uid
        );
      allow delete: if isAdmin() ||
        (
          signedIn() &&
          resource.data.followerId == request.auth.uid
        );
      allow update: if false;
    }

    match /followers/{followerId} {
      allow read: if signedIn();
      allow create: if isAdmin() ||
        (
          signedIn() &&
          request.resource.data.followerId == request.auth.uid &&
          request.resource.data.followingId is string &&
          request.resource.data.followingId != request.auth.uid
        );
      allow delete: if isAdmin() ||
        (
          signedIn() &&
          resource.data.followerId == request.auth.uid
        );
      allow update: if false;
    }

    match /driverLocations/{driverId} {
      allow read: if signedIn();
      allow write: if isUser(driverId) || isAdmin();
    }

    match /boosts/{boostId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isUser(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /walletSecurity/{userId} {
      allow read, write: if isUser(userId) || isAdmin();
    }

    match /walletTopups/{topupId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /walletTransactions/{transactionId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /withdrawalRequests/{withdrawalId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /verifications/{verificationId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /moderatorApplications/{applicationId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending_review'
        && request.resource.data.acceptedTerms == true;

      allow read: if isAdmin() ||
        (
          signedIn() &&
          resource.data.userId == request.auth.uid
        );

      allow update: if isAdmin() ||
        (
          signedIn() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          resource.data.status in ['pending_review', 'rejected'] &&
          request.resource.data.status == 'pending_review' &&
          request.resource.data.acceptedTerms == true &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName',
            'phoneNumber',
            'cityOrRegion',
            'routes',
            'routeKeys',
            'transportCapacity',
            'identityDocumentUrl',
            'acceptedTerms',
            'status',
            'updatedAt'
          ])
        );

      allow delete: if isAdmin();
    }

    match /moderatorDeliveries/{requestId} {
      allow create: if validModeratorDeliveryCreate(request.resource.data);

      allow read: if isModeratorDeliveryParticipant(resource.data);

      allow update: if isAdmin() ||
        assignedModeratorCanUpdateDelivery() ||
        buyerCanRequestModeratorPayment();

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isModeratorDeliveryParticipant(
          get(/databases/$(database)/documents/moderatorDeliveries/$(requestId)).data
        );

        allow create: if isModeratorDeliveryParticipant(
          get(/databases/$(database)/documents/moderatorDeliveries/$(requestId)).data
        )
          && (
            isAdmin() ||
            request.resource.data.senderId == request.auth.uid ||
            request.resource.data.userId == request.auth.uid
          );

        allow update: if isModeratorDeliveryParticipant(
          get(/databases/$(database)/documents/moderatorDeliveries/$(requestId)).data
        );

        allow delete: if isAdmin();
      }
    }

    match /platformRevenue/{revenueId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /emailCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /deliveryRequests/{requestId} {
      allow read: if signedIn()
        && (
          isAdmin() ||
          isDeliveryParticipant(resource.data)
        );

      allow create: if signedIn()
        && (
          isAdmin() ||
          request.resource.data.buyerId == request.auth.uid ||
          request.resource.data.sellerId == request.auth.uid ||
          request.resource.data.driverId == request.auth.uid ||
          request.resource.data.assignedDriverId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.createdBy == request.auth.uid ||
          request.resource.data.requesterId == request.auth.uid ||
          request.resource.data.requestedBy == request.auth.uid ||
          (
            request.resource.data.tradeId is string &&
            isTradeParticipantById(request.resource.data.tradeId)
          )
        );

      allow update: if isDeliveryParticipant(resource.data) ||
        isDeliveryParticipant(request.resource.data);

      allow delete: if isAdmin();

      match /offers/{offerId} {
        allow read: if isDeliveryParticipantById(requestId);
        allow create: if isDeliveryParticipantById(requestId);
        allow update: if isDeliveryParticipantById(requestId);
        allow delete: if isAdmin();
      }

      match /driverOffers/{offerId} {
        allow read: if isDeliveryParticipantById(requestId);
        allow create: if isDeliveryParticipantById(requestId);
        allow update: if isDeliveryParticipantById(requestId);
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isDeliveryParticipantById(requestId);

        allow create: if isDeliveryParticipantById(requestId)
          && (
            isAdmin() ||
            request.resource.data.senderId == request.auth.uid ||
            request.resource.data.userId == request.auth.uid ||
            request.resource.data.createdBy == request.auth.uid
          );

        allow update: if isDeliveryParticipantById(requestId);
        allow delete: if isAdmin();
      }

      match /{subCollection}/{docId} {
        allow read: if isDeliveryParticipantById(requestId);
        allow create: if isDeliveryParticipantById(requestId);
        allow update: if isDeliveryParticipantById(requestId);
        allow delete: if isAdmin();
      }
    }

    match /deliveries/{deliveryId} {
      allow read: if signedIn()
        && (
          isAdmin() ||
          isDeliveryParticipant(resource.data)
        );

      allow create: if signedIn()
        && (
          isAdmin() ||
          request.resource.data.buyerId == request.auth.uid ||
          request.resource.data.sellerId == request.auth.uid ||
          request.resource.data.driverId == request.auth.uid ||
          request.resource.data.assignedDriverId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.createdBy == request.auth.uid ||
          request.resource.data.requesterId == request.auth.uid ||
          request.resource.data.requestedBy == request.auth.uid ||
          (
            request.resource.data.tradeId is string &&
            isTradeParticipantById(request.resource.data.tradeId)
          )
        );

      allow update: if isDeliveryParticipant(resource.data) ||
        isDeliveryParticipant(request.resource.data);

      allow delete: if isAdmin();
    }

    match /home/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
