rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          request.auth.token.email == 'realmswebs@gmail.com' &&
          request.auth.token.email_verified == true
        )
      );
    }

    function isServer() {
      return request.auth == null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function tradeDoc(tradeId) {
      return get(/databases/$(database)/documents/trades/$(tradeId)).data;
    }

    function listingDoc(listingId) {
      return get(/databases/$(database)/documents/listings/$(listingId)).data;
    }

    function isTradeBuyer(tradeId) {
      return isSignedIn() &&
        tradeDoc(tradeId).buyerId == request.auth.uid;
    }

    function isTradeSeller(tradeId) {
      return isSignedIn() &&
        tradeDoc(tradeId).sellerId == request.auth.uid;
    }

    function isTradeDriver(tradeId) {
      return isSignedIn() && (
        tradeDoc(tradeId).driverId == request.auth.uid ||
        tradeDoc(tradeId).assignedDriverId == request.auth.uid
      );
    }

    function isTradeParticipant(tradeId) {
      return isSignedIn() && (
        tradeDoc(tradeId).buyerId == request.auth.uid ||
        tradeDoc(tradeId).sellerId == request.auth.uid ||
        tradeDoc(tradeId).driverId == request.auth.uid ||
        tradeDoc(tradeId).assignedDriverId == request.auth.uid ||
        isAdmin()
      );
    }

    function immutableTradeParticipants() {
      return incoming().buyerId == existing().buyerId
        && incoming().sellerId == existing().sellerId
        && incoming().listingId == existing().listingId;
    }

    // =========================
    // VALIDATORS
    // =========================

    function isValidUser(data) {
      let isAssigningAdmin =
        data.roles is list &&
        data.roles.hasAny(['admin']);

      return data.userId == request.auth.uid

        && data.roles is list

        && (!isAssigningAdmin || isAdmin())

        && (
          data.activeRole == null ||
          data.activeRole in ['buyer', 'seller', 'driver', 'admin']
        )

        && (
          data.role == null ||
          data.role in ['buyer', 'seller', 'driver', 'admin']
        )

        && (
          data.verificationStatus == null ||
          data.verificationStatus in [
            'unverified',
            'pending',
            'verified',
            'rejected'
          ]
        )

        && (
          data.displayName == null ||
          (data.displayName is string && data.displayName.size() <= 100)
        )

        && (
          data.email == null ||
          (data.email is string && data.email.size() <= 100)
        )

        && (
          data.phoneNumber == null ||
          (data.phoneNumber is string && data.phoneNumber.size() <= 20)
        )

        && (
          data.photoURL == null ||
          (data.photoURL is string && data.photoURL.size() <= 500)
        )

        && (
          data.lastActiveAt == null ||
          data.lastActiveAt is timestamp
        )

        && (
          data.createdAt == null ||
          data.createdAt is timestamp
        )

        && (
          data.updatedAt == null ||
          data.updatedAt is timestamp
        )

        && (
          data.driverStatus == null ||
          data.driverStatus in [
            'available',
            'busy',
            'offline',
            'on_trip',
            'unavailable'
          ]
        )

        && (
          data.availability == null ||
          data.availability in [
            'available',
            'busy',
            'offline',
            'on_trip',
            'unavailable'
          ]
        )

        && (
          data.vehicleType == null ||
          data.vehicleType is string
        )

        && (
          data.deliveriesCount == null ||
          data.deliveriesCount is int
        )

        && (
          data.avgDriverRating == null ||
          data.avgDriverRating is number
        )

        && (
          data.averageRating == null ||
          data.averageRating is number
        )

        && (
          data.reliabilityScore == null ||
          data.reliabilityScore is number
        )

        && (
          data.badge == null ||
          data.badge is string
        )

        && (
          data.badges == null ||
          data.badges is list
        )

        && (
          data.sellerTier == null ||
          data.sellerTier in [
            'none',
            'elite',
            'trusted',
            'official'
          ]
        )

        && (
          data.driverTier == null ||
          data.driverTier in [
            'none',
            'trusted',
            'master'
          ]
        )

        && (
          data.totalEarnings == null ||
          data.totalEarnings is number
        )

        && (
          data.totalTrades == null ||
          data.totalTrades is int
        )

        && (
          data.followersCount == null ||
          data.followersCount is int
        )

        && (
          data.followingCount == null ||
          data.followingCount is int
        )

        && (
          data.isBanned == null ||
          data.isBanned is bool
        )

        && (
          data.warningCount == null ||
          data.warningCount is int
        )

        && (
          data.isSuspended == null ||
          data.isSuspended is bool
        )

        && (
          data.suspensionUntil == null ||
          data.suspensionUntil is timestamp
        )

        && (
          data.riskLevel == null ||
          data.riskLevel in [
            'none',
            'low',
            'medium',
            'high'
          ]
        )

        && (
          data.riskFlags == null ||
          data.riskFlags is list
        )

        && (
          data.isAdmin == null ||
          data.isAdmin is bool
        )

        && (
          data.isSeller == null ||
          data.isSeller is bool
        )

        && (
          data.fcmToken == null ||
          data.fcmToken is string
        );
    }

    function isValidListing(data) {

      return (
          data.ownerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          data.userId == request.auth.uid ||
          data.createdBy == request.auth.uid
        )

        && data.title is string
        && data.title.size() <= 150

        && data.price is number
        && data.price >= 0

        && (
          data.status == null ||
          data.status in [
            'active',
            'available',
            'sold',
            'deleted',
            'cancelled',
            'reserved',
            'in_trade'
          ]
        )

        && (
          data.category == null ||
          data.category in [
            'Animals',
            'Farming Products',
            'Electronics',
            'Equipment',
            'Seeds',
            'Crops',
            'Livestock',
            'Other'
          ]
        )

        && (
          data.inventoryType == null ||
          data.inventoryType in [
            'single',
            'stock',
            'single_product',
            'multiple'
          ]
        )

        && (
          data.listingStatus == null ||
          data.listingStatus in [
            'available',
            'reserved',
            'in_trade',
            'sold',
            'cancelled',
            'active'
          ]
        )

        && (
          data.description == null ||
          data.description is string
        )

        && (
          data.priceDisplay == null ||
          data.priceDisplay is string
        )

        && (
          data.quantity == null ||
          data.quantity is string ||
          data.quantity is number ||
          data.quantity is int
        )

        && (
          data.currency == null ||
          data.currency is string
        )

        && (
          data.currencyCode == null ||
          data.currencyCode is string
        )

        && (
          data.currencyLocale == null ||
          data.currencyLocale is string
        )

        && (
          data.currencyLabel == null ||
          data.currencyLabel is string
        )

        && (
          data.country == null ||
          data.country is string
        )

        && (
          data.metadata == null ||
          data.metadata is map
        )

        && (
          data.images == null ||
          data.images is list
        )

        && (
          data.failedImageNames == null ||
          data.failedImageNames is list
        )

        && (
          data.imageUploadStatus == null ||
          data.imageUploadStatus in [
            'none',
            'uploaded',
            'partial',
            'failed'
          ]
        )

        && (
          data.location == null ||
          data.location is string ||
          data.location is map
        )

        && (
          data.locationName == null ||
          data.locationName is string
        )

        && (
          data.latitude == null ||
          data.latitude is number
        )

        && (
          data.longitude == null ||
          data.longitude is number
        )

        && (
          data.currentLocation == null ||
          data.currentLocation is map
        )

        && (
          data.gpsAccuracy == null ||
          data.gpsAccuracy is number
        )

        && (
          data.gpsSource == null ||
          data.gpsSource is string
        )

        && (
          data.isGeoTagged == null ||
          data.isGeoTagged is bool
        )

        && (
          data.stockStatus == null ||
          data.stockStatus is string
        )

        && (
          data.activeTradeId == null ||
          data.activeTradeId is string
        )

        && (
          data.soldAt == null ||
          data.soldAt is timestamp
        )

        && (
          data.reservedAt == null ||
          data.reservedAt is timestamp
        )

        && (
          data.isBoosted == null ||
          data.isBoosted is bool
        )

        && (
          data.boostTier == null ||
          data.boostTier in [
            'standard',
            'premium'
          ]
        )

        && (
          data.boostExpiresAt == null ||
          data.boostExpiresAt is timestamp
        )

        && (
          data.createdAt == null ||
          data.createdAt is timestamp
        )

        && (
          data.updatedAt == null ||
          data.updatedAt is timestamp
        );
    }

    function isValidTrade(data) {
      return (
          data.buyerId == request.auth.uid ||
          data.sellerId == request.auth.uid ||
          isAdmin()
        )

        && data.buyerId is string
        && data.sellerId is string
        && data.buyerId != data.sellerId

        && data.status in [
          'pending',
          'funded',
          'shipped',
          'completed',
          'disputed',
          'cancelled'
        ]

        && data.amount is number
        && data.amount >= 0;
    }

    function isValidNotification(data) {
      return data.title is string
        && data.body is string;
    }

    // =========================
    // USERS
    // =========================

    match /users/{userId} {

      allow get: if true;
      allow list: if true;

      allow create: if
        isOwner(userId)
        && isValidUser(incoming());

      allow update: if (

        isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly([

          'lastActiveAt',
          'fcmToken',
          'followersCount',
          'followingCount',
          'driverStatus',
          'availability',
          'isOnline',
          'online',
          'currentLocation',
          'latitude',
          'longitude',
          'locationUpdatedAt',
          'vehicleType',
          'roles',
          'role',
          'activeRole',
          'isSeller',
          'updatedAt',
          'photoURL',
          'displayName',
          'name'

        ])

      ) || isServer() || isAdmin();
    }

    // =========================
    // LISTINGS
    // =========================

    match /listings/{listingId} {

      allow get: if true;
      allow list: if true;

      allow create: if
        isSignedIn()
        && isValidListing(incoming())
        && (
          incoming().ownerId == request.auth.uid ||
          incoming().sellerId == request.auth.uid ||
          incoming().userId == request.auth.uid ||
          incoming().createdBy == request.auth.uid
        );

      allow update: if
        isServer()
        || isAdmin()
        || (
          isSignedIn()
          && (
            existing().ownerId == request.auth.uid ||
            existing().sellerId == request.auth.uid ||
            existing().userId == request.auth.uid ||
            existing().createdBy == request.auth.uid
          )
          && isValidListing(incoming())
        );

      allow delete: if
        isAdmin()
        || (
          isSignedIn()
          && (
            existing().ownerId == request.auth.uid ||
            existing().sellerId == request.auth.uid
          )
        );
    }

    // =========================
    // TRADES
    // =========================

    match /trades/{tradeId} {

      allow get: if isTradeParticipant(tradeId);
      allow list: if isSignedIn();

      allow create: if
        isSignedIn()
        && isValidTrade(incoming());

      allow update: if
        isServer()
        || isAdmin()
        || (
          isSignedIn()
          && isTradeParticipant(tradeId)
          && immutableTradeParticipants()
        );
    }

    // =========================
    // MESSAGES
    // =========================

    match /trades/{tradeId}/messages/{messageId} {

      allow list, get: if isTradeParticipant(tradeId);

      allow create: if
        isTradeParticipant(tradeId);
    }

    match /messages/{messageId} {

      allow list, get: if
        resource.data.tradeId is string
        && isTradeParticipant(resource.data.tradeId);

      allow create: if
        incoming().tradeId is string
        && isTradeParticipant(incoming().tradeId);
    }

    // =========================
    // REVIEWS
    // =========================

    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if
        isSignedIn();
    }

    // =========================
    // DRIVER RATINGS
    // =========================

    match /driver_ratings/{ratingId} {

      allow read: if true;

      allow create: if
        isSignedIn();
    }

    // =========================
    // REPORTS
    // =========================

    match /reports/{reportId} {

      allow get: if
        isAdmin()
        || (
          isSignedIn()
          && resource.data.reporterId == request.auth.uid
        );

      allow list: if isAdmin();

      allow create: if isSignedIn();

      allow update: if isAdmin();
    }

    // =========================
    // NOTIFICATIONS
    // =========================

    match /notifications/{notifId} {

      allow read: if
        isSignedIn()
        || isServer();

      allow create: if
        isSignedIn()
        || isServer();

      allow update: if
        isAdmin()
        || isServer();
    }

    // =========================
    // WALLET
    // =========================

    match /wallets/{walletId} {
      allow read: if isOwner(walletId) || isAdmin();
      allow write: if false;
    }

    match /walletTransactions/{transactionId} {
      allow read: if
        isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdmin()
        );

      allow write: if false;
    }

    // =========================
    // FALLBACK
    // =========================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
